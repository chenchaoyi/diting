{
  "name": "diting-companion-relay",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "End-to-end-encrypted store-and-forward relay for diting companion pairing (Cloudflare Worker + D1).",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate:local": "wrangler d1 migrations apply diting-companion --local",
    "migrate:remote": "wrangler d1 migrations apply diting-companion --remote",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.8.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
