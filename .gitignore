# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments (uv puts venvs at .venv by default)
.venv/
venv/
env/

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# IDE / editor
.idea/
.vscode/
*.swp
*~

# Swift helper build artefacts
helper/.build/
helper/.swiftpm/
helper/Package.resolved
helper/wifiscope-helper.app/

# NOTE: do NOT ignore uv.lock or .python-version — both are committed for
# reproducible installs (uv treats this as an application, not a library).
