# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
# PyInstaller writes <name>.spec at the repo root on the first run
# of `scripts/build_frozen.py`. The build script is the source of
# truth for the freeze config; the generated .spec is regenerated
# every build and never checked in.
diting.spec

# Virtual environments (uv puts venvs at .venv by default)
.venv/
venv/
env/

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# macOS
.DS_Store

# IDE / editor
.idea/
.vscode/
*.swp
*~

# Swift helper build artefacts
helper/.build/
helper/.swiftpm/
helper/Package.resolved
helper/diting-tianer.app/
helper/wifiscope-helper.app/

# User's own AP aliases — created by copying aps.example.yaml. Contains
# the user's network topology (mgmt MACs + AP names), which has no
# business in version control and would expose private deployment info.
aps.yaml

# Event log files produced by `diting --log` and `diting monitor`.
# Contain MAC addresses / SSIDs / timestamps from the user's network and
# have no place in source control. The default-named pattern catches
# anything written via `diting --log` (no path) and the documented
# example filenames; users who pass an explicit path elsewhere stay
# uncovered — that location was their choice.
diting-*.jsonl
wifiscope-*.jsonl

# `scripts/tui_snapshot.py` (and the `/tui-audit` slash command) write
# captured screenshots + JSON report under ./snapshot-output/ by default.
# Treat as ephemeral artefacts — the canonical preview SVGs live under
# docs/ instead.
snapshot-output/

# NOTE: do NOT ignore uv.lock or .python-version — both are committed for
# reproducible installs (uv treats this as an application, not a library).

# Personal/meeting notes — never commit. Keep these out of the public repo.
会议纪要_*.md
/会议纪要*.md

# Claude Code scheduled-task local state.
.claude/scheduled_tasks.lock
