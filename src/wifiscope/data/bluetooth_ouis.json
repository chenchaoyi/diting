{
  "_meta": {
    "purpose": "MAC-address-OUI to vendor-name mapping. Used for connected BLE peripherals that arrive via IOBluetoothDevice (system-paired keyboards / mice / headphones), where the BLE advertisement's manufacturer-id is not available. Lookup keys are lowercase, colon-separated 3-octet prefixes (e.g. '38:09:fb'). Curated subset of the public IEEE MA-L OUI registry, prioritising vendors that ship Bluetooth peripherals. Apple coverage is comprehensive; other vendors are best-effort. Update via scripts/update_ouis.py (writes file in place from the upstream registry).",
    "source": "IEEE MA-L registry, public",
    "fetched_at": "2026-05-07",
    "scope": "common BLE peripheral vendors only — full IEEE registry is ~30k entries"
  },

