<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>

    <key>CFBundleExecutable</key>
    <string>diting-tianer</string>

    <key>CFBundleIdentifier</key>
    <string>com.chenchaoyi.diting.tianer</string>

    <!-- Packed by helper/build.sh from Resources/AppIcon.iconset
         via `iconutil --convert icns`. The PNG sources are
         committed (see scripts/build_app_icon.py for the
         pixel-art-from-logo-mark renderer). Adding this key bumps
         the bundle's cdhash, so users upgrading from a v1.0.x
         that lacked it will re-grant TCC permissions once. -->
    <key>CFBundleIconFile</key>
    <string>AppIcon</string>

    <!-- CFBundleName / CFBundleDisplayName here are the English
         defaults (fallback for any locale not in our lproj list).
         The real per-locale display strings live in
         Resources/{en,zh-Hans}.lproj/InfoPlist.strings so macOS
         picks the user's preferred language for both the TCC prompt
         header AND the prompt body
         (NSLocationUsageDescription / NSBluetoothAlwaysUsageDescription).
         Older macOS that doesn't honour CFBundleLocalizations still
         falls back to these top-level values. -->
    <key>CFBundleName</key>
    <string>diting · tianer</string>

    <key>CFBundleDisplayName</key>
    <string>diting · tianer</string>

    <key>CFBundleLocalizations</key>
    <array>
        <string>en</string>
        <string>zh-Hans</string>
    </array>

    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <key>CFBundleShortVersionString</key>
    <string>0.5.0</string>

    <key>CFBundleVersion</key>
    <string>1</string>

    <key>LSMinimumSystemVersion</key>
    <string>11.0</string>

    <key>NSPrincipalClass</key>
    <string>NSApplication</string>

    <key>NSHighResolutionCapable</key>
    <true/>

    <key>NSLocationUsageDescription</key>
    <string>diting reads nearby Wi-Fi network names and BSSIDs to label access points and detect roaming. Location data never leaves your machine.</string>

    <key>NSLocationWhenInUseUsageDescription</key>
    <string>diting reads nearby Wi-Fi network names and BSSIDs to label access points and detect roaming. Location data never leaves your machine.</string>

    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>diting scans nearby BLE advertisements so the TUI can show you what devices are around</string>

    <!-- macOS does not require a usage description for
         UNUserNotificationCenter, but lproj per-locale variants
         in en.lproj / zh-Hans.lproj/InfoPlist.strings give the
         third install-time prompt a friendly header. -->

    <!-- LSUIElement=true makes the bundle a "background-only / agent
         app": no Dock icon, no Cmd+Tab presence, no Force-Quit entry.
         Windows still work (the install-time HelperAppDelegate's
         status panel is unchanged) and TCC grants still attach by
         CFBundleIdentifier / cdhash, so the install flow + the
         LaunchServices-attributed `scan` and `notify` paths still
         get Location / Bluetooth / Notifications authorisation.

         Why not `false` (regular app): every `scan` / `notify` from
         Python re-launches the bundle via LaunchServices to inherit
         the bundle's TCC grant (the v1.0.7 macOS-26 finding). With
         LSUIElement=false the Dock icon flashes briefly on every
         such call. Agent-app mode removes that flash entirely. -->
    <key>LSUIElement</key>
    <true/>
</dict>
</plist>
